---
const currentLang = Astro.currentLocale || 'en';

const t = {
  en: {
    title1: "1. Select SVG Files",
    subtitle1: "Merge multiple icons into one local SVG sprite. Files are read in your browser only.",
    choose: "Choose SVG files",
    clear: "Clear",
    title2: "2. Sprite Output",
    copy: "Copy",
    copied: "Copied!",
    download: "Download",
    symbols: "Symbols",
    usage: "Usage",
    placeholderOutput: "SVG sprite markup will appear here...",
    empty: "Select one or more SVG files first.",
    invalid: "Some files were skipped because they were not valid SVG files."
  },
  zh: {
    title1: "1. 选择 SVG 文件",
    subtitle1: "在浏览器本地将多个图标合并为一个 SVG Sprite。文件不会上传。",
    choose: "选择 SVG 文件",
    clear: "清空",
    title2: "2. Sprite 输出",
    copy: "复制",
    copied: "已复制!",
    download: "下载",
    symbols: "图标列表",
    usage: "使用方式",
    placeholderOutput: "SVG Sprite 代码将在此处生成...",
    empty: "请先选择一个或多个 SVG 文件。",
    invalid: "部分文件不是有效 SVG，已跳过。"
  },
  de: {
    title1: "1. SVG-Dateien auswählen",
    subtitle1: "Führen Sie mehrere Icons lokal im Browser zu einem SVG-Sprite zusammen.",
    choose: "SVG-Dateien wählen",
    clear: "Leeren",
    title2: "2. Sprite-Ausgabe",
    copy: "Kopieren",
    copied: "Kopiert!",
    download: "Herunterladen",
    symbols: "Symbole",
    usage: "Verwendung",
    placeholderOutput: "SVG-Sprite-Markup wird hier angezeigt...",
    empty: "Wählen Sie zuerst eine oder mehrere SVG-Dateien.",
    invalid: "Einige Dateien wurden übersprungen, da sie keine gültigen SVG-Dateien waren."
  }
}[currentLang as 'en' | 'zh' | 'de'];
---

<section class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col gap-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h2 class="text-lg font-bold text-slate-900">{t.title1}</h2>
      <p class="text-xs text-slate-500 mt-1">{t.subtitle1}</p>
    </div>
    <div class="flex items-center gap-2">
      <label class="inline-flex cursor-pointer items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-xs font-bold text-white transition-colors hover:bg-indigo-700">
        {t.choose}
        <input id="spriteFiles" type="file" accept=".svg,image/svg+xml" multiple class="sr-only" />
      </label>
      <button id="clearSprite" type="button" class="rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-xs font-bold text-slate-600 hover:bg-slate-50">
        {t.clear}
      </button>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-4">
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <div class="flex items-center justify-between gap-3">
        <h3 class="text-xs font-bold uppercase tracking-wide text-slate-500">{t.symbols}</h3>
        <span id="symbolCount" class="rounded-full bg-white px-2 py-1 text-[11px] font-bold text-slate-500 border border-slate-200">0</span>
      </div>
      <div id="symbolList" class="mt-4 flex flex-col gap-2 text-xs text-slate-500"></div>
      <p id="spriteStatus" class="mt-4 min-h-4 text-xs font-semibold text-red-600">{t.empty}</p>
    </div>

    <div class="flex flex-col gap-3">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg font-bold text-slate-900">{t.title2}</h2>
        <div class="flex items-center gap-2">
          <button id="copySprite" data-text={t.copy} class="text-indigo-600 hover:text-indigo-800 font-bold px-2 py-1 bg-indigo-50 rounded hover:bg-indigo-100 transition-colors text-xs">{t.copy}</button>
          <button id="downloadSprite" type="button" class="text-emerald-700 hover:text-emerald-900 font-bold px-2 py-1 bg-emerald-50 rounded hover:bg-emerald-100 transition-colors text-xs">{t.download}</button>
        </div>
      </div>
      <textarea
        id="spriteOutput"
        readonly
        rows="12"
        class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl font-mono text-xs text-slate-600 break-all focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all cursor-text"
        placeholder={t.placeholderOutput}
      ></textarea>
      <div>
        <h3 class="mb-2 text-xs font-bold uppercase tracking-wide text-slate-500">{t.usage}</h3>
        <textarea
          id="spriteUsage"
          readonly
          rows="5"
          class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl font-mono text-xs text-slate-600 break-all focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all cursor-text"
        ></textarea>
      </div>
    </div>
  </div>
</section>

<input type="hidden" id="spriteEmptyMsg" value={t.empty} />
<input type="hidden" id="spriteInvalidMsg" value={t.invalid} />
<input type="hidden" id="spriteCopiedMsg" value={t.copied} />

<script>
  const fileInput = document.getElementById('spriteFiles') as HTMLInputElement;
  const clearButton = document.getElementById('clearSprite') as HTMLButtonElement;
  const output = document.getElementById('spriteOutput') as HTMLTextAreaElement;
  const usage = document.getElementById('spriteUsage') as HTMLTextAreaElement;
  const status = document.getElementById('spriteStatus');
  const symbolList = document.getElementById('symbolList');
  const symbolCount = document.getElementById('symbolCount');
  const copyButton = document.getElementById('copySprite') as HTMLButtonElement;
  const downloadButton = document.getElementById('downloadSprite') as HTMLButtonElement;
  const emptyMsg = (document.getElementById('spriteEmptyMsg') as HTMLInputElement)?.value || 'Select one or more SVG files first.';
  const invalidMsg = (document.getElementById('spriteInvalidMsg') as HTMLInputElement)?.value || 'Some files were skipped.';
  const copiedMsg = (document.getElementById('spriteCopiedMsg') as HTMLInputElement)?.value || 'Copied!';
  let selectedFiles: File[] = [];

  type SymbolItem = {
    id: string;
    viewBox: string;
    attrs: string;
    content: string;
    name: string;
  };

  const parseSvg = (svgCode: string) => {
    const doc = new DOMParser().parseFromString(svgCode, 'image/svg+xml');
    if (doc.querySelector('parsererror')) return null;
    const svg = doc.documentElement;
    if (!svg || svg.tagName.toLowerCase() !== 'svg') return null;
    return svg;
  };

  const sanitizeId = (fileName: string, index: number) => {
    const base = fileName.replace(/\.svg$/i, '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    return base ? `icon-${base}` : `icon-${index + 1}`;
  };

  const sanitizeSvgElement = (svg: SVGElement) => {
    const clone = svg.cloneNode(true) as SVGElement;
    clone.querySelectorAll('script, foreignObject').forEach((node) => node.remove());
    clone.querySelectorAll('*').forEach((node) => {
      [...node.attributes].forEach((attr) => {
        const name = attr.name.toLowerCase();
        const value = attr.value.trim().toLowerCase();
        if (name.startsWith('on') || value.startsWith('javascript:')) {
          node.removeAttribute(attr.name);
        }
      });
    });
    return clone;
  };

  const makeSymbol = (svg: SVGElement, fileName: string, index: number, usedIds: Set<string>): SymbolItem => {
    const clean = sanitizeSvgElement(svg);
    let id = sanitizeId(fileName, index);
    let suffix = 2;
    while (usedIds.has(id)) {
      id = `${sanitizeId(fileName, index)}-${suffix}`;
      suffix += 1;
    }
    usedIds.add(id);

    const viewBox = clean.getAttribute('viewBox') || `0 0 ${clean.getAttribute('width') || 24} ${clean.getAttribute('height') || 24}`;
    const preservedAttrs = ['fill', 'stroke', 'stroke-width', 'stroke-linecap', 'stroke-linejoin', 'stroke-miterlimit', 'fill-rule', 'clip-rule', 'color', 'opacity'];
    const attrs = preservedAttrs
      .filter((name) => clean.hasAttribute(name))
      .map((name) => `${name}="${clean.getAttribute(name)}"`)
      .join(' ');
    const content = [...clean.childNodes].map((node) => new XMLSerializer().serializeToString(node)).join('');

    return { id, viewBox, attrs, content, name: fileName };
  };

  const render = (symbols: SymbolItem[], skipped: number) => {
    symbolCount!.textContent = String(symbols.length);
    symbolList?.replaceChildren();

    symbols.forEach((symbol) => {
      const item = document.createElement('div');
      item.className = 'rounded-lg border border-slate-200 bg-white px-3 py-2 font-mono text-[11px] text-slate-600';
      item.textContent = `#${symbol.id}`;
      symbolList?.appendChild(item);
    });

    if (!symbols.length) {
      output.value = '';
      usage.value = '';
      status!.textContent = emptyMsg;
      return;
    }

    output.value = `<svg xmlns="http://www.w3.org/2000/svg" style="display:none">\n${symbols.map((symbol) => `  <symbol id="${symbol.id}" viewBox="${symbol.viewBox}"${symbol.attrs ? ` ${symbol.attrs}` : ''}>${symbol.content}</symbol>`).join('\n')}\n</svg>`;
    usage.value = symbols.map((symbol) => `<svg aria-hidden="true"><use href="#${symbol.id}"></use></svg>`).join('\n');
    status!.textContent = skipped ? invalidMsg : '';
  };

  const handleFiles = async () => {
    const incomingFiles = [...(fileInput.files || [])];
    selectedFiles = [...selectedFiles, ...incomingFiles];

    const symbols: SymbolItem[] = [];
    const usedIds = new Set<string>();
    let skipped = 0;

    for (const [index, file] of selectedFiles.entries()) {
      const text = await file.text();
      const parsed = parseSvg(text);
      if (!parsed) {
        skipped += 1;
        continue;
      }
      symbols.push(makeSymbol(parsed, file.name, index, usedIds));
    }

    render(symbols, skipped);
    fileInput.value = '';
  };

  fileInput?.addEventListener('change', handleFiles);
  clearButton?.addEventListener('click', () => {
    selectedFiles = [];
    fileInput.value = '';
    render([], 0);
  });
  output?.addEventListener('click', () => output.value && output.select());
  usage?.addEventListener('click', () => usage.value && usage.select());
  copyButton?.addEventListener('click', () => {
    if (!output.value) return;
    navigator.clipboard.writeText(output.value);
    const originalText = copyButton.getAttribute('data-text') || 'Copy';
    copyButton.innerText = copiedMsg;
    setTimeout(() => copyButton.innerText = originalText, 1500);
  });
  downloadButton?.addEventListener('click', () => {
    if (!output.value) return;
    const blob = new Blob([output.value], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'sprite.svg';
    link.click();
    URL.revokeObjectURL(url);
  });
</script>
