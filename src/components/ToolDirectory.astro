---
const currentLang = Astro.currentLocale || 'en';

const pathFor = (slug: string) => currentLang === 'en' ? `/${slug}/` : `/${currentLang}/${slug}/`;

const copy = {
  en: {
    title: 'NanoSVG Tools',
    intro: 'A local-first SVG toolbox for frontend developers. Choose a tool and keep every conversion inside your browser.',
    available: 'Available Tools',
    upcoming: 'Upcoming Conversions',
    open: 'Open tool',
    soon: 'Coming soon',
    tools: [
      {
        name: 'SVG to Base64',
        desc: 'Convert SVG markup into CSS Data URI and Base64 strings for img src or background-image.',
        href: pathFor('svg2base64'),
        accent: 'bg-indigo-50 text-indigo-700 border-indigo-100'
      },
      {
        name: 'SVG Optimizer',
        desc: 'Compress SVG markup with browser-side SVGO and compare file sizes before copying.',
        href: pathFor('optimizer'),
        accent: 'bg-emerald-50 text-emerald-700 border-emerald-100'
      },
      {
        name: 'SVG to React',
        desc: 'Turn raw SVG into JSX or TSX components with React-friendly attributes.',
        href: pathFor('component'),
        accent: 'bg-sky-50 text-sky-700 border-sky-100'
      },
      {
        name: 'SVG Sprite',
        desc: 'Merge multiple SVG files into a symbol-based sprite with ready-to-use snippets.',
        href: pathFor('sprite'),
        accent: 'bg-amber-50 text-amber-700 border-amber-100'
      }
    ],
    future: ['SVG to PNG', 'SVG to JPG', 'SVG to WebP', 'SVG to PDF', 'SVG to Icon']
  },
  zh: {
    title: 'NanoSVG Tools',
    intro: '面向前端开发者的一站式 SVG 本地工具箱。选择一个工具开始处理，所有转换都在浏览器内完成。',
    available: '已上线工具',
    upcoming: '后续格式转换',
    open: '打开工具',
    soon: '即将推出',
    tools: [
      {
        name: 'SVG 转 Base64',
        desc: '将 SVG 源码转换为 CSS Data URI 和 Base64 字符串，用于 img src 或 background-image。',
        href: pathFor('svg2base64'),
        accent: 'bg-indigo-50 text-indigo-700 border-indigo-100'
      },
      {
        name: 'SVG 压缩优化',
        desc: '使用浏览器端 SVGO 压缩 SVG，并对比优化前后的体积。',
        href: pathFor('optimizer'),
        accent: 'bg-emerald-50 text-emerald-700 border-emerald-100'
      },
      {
        name: 'SVG 转 React 组件',
        desc: '将原始 SVG 转换为 JSX 或 TSX 组件，并处理 React 友好的属性命名。',
        href: pathFor('component'),
        accent: 'bg-sky-50 text-sky-700 border-sky-100'
      },
      {
        name: 'SVG Sprite 合并',
        desc: '将多个 SVG 文件合并为基于 symbol 的精灵图，并生成 use 用法代码。',
        href: pathFor('sprite'),
        accent: 'bg-amber-50 text-amber-700 border-amber-100'
      }
    ],
    future: ['SVG 转 PNG', 'SVG 转 JPG', 'SVG 转 WebP', 'SVG 转 PDF', 'SVG 转 Icon']
  },
  de: {
    title: 'NanoSVG Tools',
    intro: 'Eine lokale SVG-Toolbox für Frontend-Entwickler. Wählen Sie ein Werkzeug, alle Konvertierungen bleiben im Browser.',
    available: 'Verfügbare Tools',
    upcoming: 'Geplante Konvertierungen',
    open: 'Tool öffnen',
    soon: 'Bald verfügbar',
    tools: [
      {
        name: 'SVG zu Base64',
        desc: 'Konvertieren Sie SVG-Markup in CSS Data URIs und Base64-Strings für img src oder background-image.',
        href: pathFor('svg2base64'),
        accent: 'bg-indigo-50 text-indigo-700 border-indigo-100'
      },
      {
        name: 'SVG Optimizer',
        desc: 'Komprimieren Sie SVG-Markup mit SVGO im Browser und vergleichen Sie die Dateigrößen.',
        href: pathFor('optimizer'),
        accent: 'bg-emerald-50 text-emerald-700 border-emerald-100'
      },
      {
        name: 'SVG zu React',
        desc: 'Wandeln Sie SVG in JSX- oder TSX-Komponenten mit React-kompatiblen Attributen um.',
        href: pathFor('component'),
        accent: 'bg-sky-50 text-sky-700 border-sky-100'
      },
      {
        name: 'SVG Sprite',
        desc: 'Führen Sie mehrere SVG-Dateien zu einem symbolbasierten Sprite mit Use-Snippets zusammen.',
        href: pathFor('sprite'),
        accent: 'bg-amber-50 text-amber-700 border-amber-100'
      }
    ],
    future: ['SVG zu PNG', 'SVG zu JPG', 'SVG zu WebP', 'SVG zu PDF', 'SVG zu Icon']
  }
}[currentLang as 'en' | 'zh' | 'de'];
---

<section class="bg-white p-6 sm:p-8 rounded-2xl shadow-sm border border-slate-200">
  <div class="max-w-3xl">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-indigo-600">100% Client-Side</p>
    <h1 class="mt-3 text-3xl sm:text-4xl font-black text-slate-950">{copy.title}</h1>
    <p class="mt-3 text-sm sm:text-base text-slate-600 leading-relaxed">{copy.intro}</p>
  </div>
</section>

<section id="features" class="flex flex-col gap-4">
  <div class="flex items-center justify-between">
    <h2 class="text-xl font-bold text-slate-950">{copy.available}</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {copy.tools.map((tool) => (
      <a href={tool.href} class="group block rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-indigo-200 hover:shadow-md">
        <div class="flex items-start justify-between gap-4">
          <div class={`rounded-xl border px-3 py-2 text-xs font-bold ${tool.accent}`}>{tool.name}</div>
          <span class="text-slate-300 transition-colors group-hover:text-indigo-500">→</span>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-slate-600">{tool.desc}</p>
        <span class="mt-5 inline-flex text-xs font-bold text-indigo-600">{copy.open}</span>
      </a>
    ))}
  </div>
</section>

<section id="faq" class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-6">
  <h2 class="text-xl font-bold text-slate-950">{copy.upcoming}</h2>
  <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
    {copy.future.map((item) => (
      <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
        <p class="text-sm font-bold text-slate-800">{item}</p>
        <p class="mt-1 text-xs font-semibold text-slate-400">{copy.soon}</p>
      </div>
    ))}
  </div>
</section>
