---
const currentLang = Astro.currentLocale || 'en';

const t = {
  en: {
    title1: "1. Paste your SVG Code",
    subtitle1: "Optimize SVG markup locally with SVGO. Your code never leaves your browser.",
    placeholderInput: "<svg viewBox=\"0 0 24 24\"> ... </svg>",
    optimize: "Optimize SVG",
    title2: "2. Optimized Output",
    copy: "Copy",
    copied: "Copied!",
    original: "Original",
    optimized: "Optimized",
    saved: "Saved",
    originalPreview: "Original Preview",
    optimizedPreview: "Optimized Preview",
    placeholderOutput: "Optimized SVG code will appear here...",
    empty: "Paste an SVG first.",
    invalid: "Invalid SVG code structure.",
    failed: "Optimization failed. Please check your SVG code."
  },
  zh: {
    title1: "1. 粘贴您的 SVG 代码",
    subtitle1: "使用 SVGO 在浏览器本地压缩 SVG。您的代码不会离开当前设备。",
    placeholderInput: "<svg viewBox=\"0 0 24 24\"> ... </svg>",
    optimize: "压缩优化 SVG",
    title2: "2. 优化结果",
    copy: "复制",
    copied: "已复制!",
    original: "原始体积",
    optimized: "优化后",
    saved: "节省比例",
    originalPreview: "原始预览",
    optimizedPreview: "优化后预览",
    placeholderOutput: "优化后的 SVG 代码将在此处生成...",
    empty: "请先粘贴 SVG 代码。",
    invalid: "SVG 代码结构无效，请检查。",
    failed: "优化失败，请检查 SVG 代码。"
  },
  de: {
    title1: "1. SVG-Code hier einfügen",
    subtitle1: "Optimieren Sie SVG-Markup lokal mit SVGO. Ihr Code verlässt niemals den Browser.",
    placeholderInput: "<svg viewBox=\"0 0 24 24\"> ... </svg>",
    optimize: "SVG optimieren",
    title2: "2. Optimierte Ausgabe",
    copy: "Kopieren",
    copied: "Kopiert!",
    original: "Original",
    optimized: "Optimiert",
    saved: "Ersparnis",
    originalPreview: "Originalvorschau",
    optimizedPreview: "Optimierte Vorschau",
    placeholderOutput: "Optimierter SVG-Code wird hier angezeigt...",
    empty: "Fügen Sie zuerst ein SVG ein.",
    invalid: "Ungültige SVG-Codestruktur.",
    failed: "Optimierung fehlgeschlagen. Bitte prüfen Sie Ihren SVG-Code."
  }
}[currentLang as 'en' | 'zh' | 'de'];
---

<section class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col gap-6">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h2 class="text-lg font-bold text-slate-900">{t.title1}</h2>
      <p class="text-xs text-slate-500 mt-1">{t.subtitle1}</p>
    </div>
    <button
      id="optimizeSvg"
      class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-xs font-bold text-white transition-colors hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
    >
      {t.optimize}
    </button>
  </div>

  <textarea
    id="optimizerInput"
    rows="8"
    class="w-full p-4 border border-slate-300 rounded-xl font-mono text-xs focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50"
    placeholder={t.placeholderInput}
  ></textarea>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <span class="text-[11px] font-semibold uppercase tracking-wide text-slate-400">{t.original}</span>
      <p id="originalSize" class="mt-1 text-xl font-bold text-slate-900">0 B</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
      <span class="text-[11px] font-semibold uppercase tracking-wide text-slate-400">{t.optimized}</span>
      <p id="optimizedSize" class="mt-1 text-xl font-bold text-slate-900">0 B</p>
    </div>
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
      <span class="text-[11px] font-semibold uppercase tracking-wide text-emerald-600">{t.saved}</span>
      <p id="savedPercent" class="mt-1 text-xl font-bold text-emerald-700">0%</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="flex flex-col gap-2">
      <span class="text-xs font-semibold text-slate-600">{t.originalPreview}</span>
      <div class="min-h-[160px] rounded-xl border border-slate-200 bg-slate-50 p-6 flex items-center justify-center">
        <div id="originalPreview" class="max-w-[140px] max-h-[140px] flex items-center justify-center"></div>
      </div>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-xs font-semibold text-slate-600">{t.optimizedPreview}</span>
      <div class="min-h-[160px] rounded-xl border border-slate-200 bg-slate-50 p-6 flex items-center justify-center">
        <div id="optimizedPreview" class="max-w-[140px] max-h-[140px] flex items-center justify-center"></div>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-4 mt-2">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold text-slate-900">{t.title2}</h2>
      <button
        id="copyOptimized"
        data-text={t.copy}
        class="text-indigo-600 hover:text-indigo-800 font-bold px-2 py-1 bg-indigo-50 rounded hover:bg-indigo-100 transition-colors text-xs"
      >
        {t.copy}
      </button>
    </div>
    <textarea
      id="optimizerOutput"
      readonly
      rows="8"
      class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl font-mono text-xs text-slate-600 break-all focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all cursor-text"
      placeholder={t.placeholderOutput}
    ></textarea>
    <p id="optimizerStatus" class="min-h-4 text-xs font-semibold text-slate-500"></p>
  </div>
</section>

<input type="hidden" id="optimizerEmptyMsg" value={t.empty} />
<input type="hidden" id="optimizerInvalidMsg" value={t.invalid} />
<input type="hidden" id="optimizerFailedMsg" value={t.failed} />
<input type="hidden" id="optimizerCopiedMsg" value={t.copied} />

<script>
  import { optimize } from 'svgo/browser';

  const input = document.getElementById('optimizerInput') as HTMLTextAreaElement;
  const output = document.getElementById('optimizerOutput') as HTMLTextAreaElement;
  const button = document.getElementById('optimizeSvg') as HTMLButtonElement;
  const copyButton = document.getElementById('copyOptimized') as HTMLButtonElement;
  const status = document.getElementById('optimizerStatus');
  const originalPreview = document.getElementById('originalPreview');
  const optimizedPreview = document.getElementById('optimizedPreview');
  const originalSize = document.getElementById('originalSize');
  const optimizedSize = document.getElementById('optimizedSize');
  const savedPercent = document.getElementById('savedPercent');

  const emptyMsg = (document.getElementById('optimizerEmptyMsg') as HTMLInputElement)?.value || 'Paste an SVG first.';
  const invalidMsg = (document.getElementById('optimizerInvalidMsg') as HTMLInputElement)?.value || 'Invalid SVG code structure.';
  const failedMsg = (document.getElementById('optimizerFailedMsg') as HTMLInputElement)?.value || 'Optimization failed.';
  const copiedMsg = (document.getElementById('optimizerCopiedMsg') as HTMLInputElement)?.value || 'Copied!';

  const encoder = new TextEncoder();

  const byteSize = (value: string) => encoder.encode(value).length;

  const formatBytes = (bytes: number) => {
    if (bytes < 1024) return `${bytes} B`;
    return `${(bytes / 1024).toFixed(2)} KB`;
  };

  const setStats = (source: string, result: string) => {
    const sourceBytes = byteSize(source);
    const resultBytes = byteSize(result);
    const saved = sourceBytes > 0 ? Math.max(0, ((sourceBytes - resultBytes) / sourceBytes) * 100) : 0;

    if (originalSize) originalSize.textContent = formatBytes(sourceBytes);
    if (optimizedSize) optimizedSize.textContent = formatBytes(resultBytes);
    if (savedPercent) savedPercent.textContent = `${saved.toFixed(1)}%`;
  };

  const resetStats = () => {
    if (originalSize) originalSize.textContent = '0 B';
    if (optimizedSize) optimizedSize.textContent = '0 B';
    if (savedPercent) savedPercent.textContent = '0%';
  };

  const parseSvg = (svgCode: string) => {
    const doc = new DOMParser().parseFromString(svgCode, 'image/svg+xml');
    if (doc.querySelector('parsererror')) return null;

    const svg = doc.documentElement;
    if (!svg || svg.tagName.toLowerCase() !== 'svg') return null;

    return svg;
  };

  const sanitizeSvgElement = (svg: SVGElement) => {
    const clone = svg.cloneNode(true) as SVGElement;
    clone.querySelectorAll('script, foreignObject').forEach((node) => node.remove());

    clone.querySelectorAll('*').forEach((node) => {
      [...node.attributes].forEach((attr) => {
        const name = attr.name.toLowerCase();
        const value = attr.value.trim().toLowerCase();

        if (name.startsWith('on') || value.startsWith('javascript:')) {
          node.removeAttribute(attr.name);
        }
      });
    });

    return clone;
  };

  const renderPreview = (target: HTMLElement | null, svgCode: string) => {
    if (!target) return false;

    const parsedSvg = parseSvg(svgCode);
    if (!parsedSvg) {
      target.replaceChildren();
      return false;
    }

    const cleanSvg = sanitizeSvgElement(parsedSvg);
    cleanSvg.setAttribute('width', '100%');
    cleanSvg.setAttribute('height', '100%');
    target.replaceChildren(document.importNode(cleanSvg, true));
    return true;
  };

  const optimizeSvg = () => {
    const source = input.value.trim();
    status?.classList.remove('text-red-600', 'text-emerald-600');

    if (!source) {
      output.value = '';
      status!.textContent = emptyMsg;
      status?.classList.add('text-red-600');
      originalPreview?.replaceChildren();
      optimizedPreview?.replaceChildren();
      resetStats();
      return;
    }

    const parsedSvg = parseSvg(source);
    if (!parsedSvg) {
      output.value = '';
      status!.textContent = invalidMsg;
      status?.classList.add('text-red-600');
      originalPreview?.replaceChildren();
      optimizedPreview?.replaceChildren();
      resetStats();
      return;
    }

    try {
      renderPreview(originalPreview, source);

      const result = optimize(source, {
        multipass: true,
        plugins: [
          {
            name: 'preset-default',
            params: {
              overrides: {
                removeViewBox: false,
                removeUselessStrokeAndFill: false,
                removeUnknownsAndDefaults: {
                  keepDataAttrs: false
                }
              }
            }
          },
          'removeDimensions'
        ]
      });

      const optimizedSvg = result.data.trim();
      if (!parseSvg(optimizedSvg)) {
        throw new Error('SVGO returned invalid SVG');
      }

      output.value = optimizedSvg;
      setStats(source, optimizedSvg);
      renderPreview(optimizedPreview, optimizedSvg);
      status!.textContent = '';
    } catch (error) {
      output.value = '';
      status!.textContent = failedMsg;
      status?.classList.add('text-red-600');
      optimizedPreview?.replaceChildren();
      resetStats();
    }
  };

  button?.addEventListener('click', optimizeSvg);
  input?.addEventListener('input', () => {
    if (!input.value.trim()) {
      output.value = '';
      status!.textContent = '';
      originalPreview?.replaceChildren();
      optimizedPreview?.replaceChildren();
      resetStats();
      return;
    }

    optimizeSvg();
  });

  copyButton?.addEventListener('click', () => {
    if (!output.value) return;

    navigator.clipboard.writeText(output.value);
    const originalText = copyButton.getAttribute('data-text') || 'Copy';
    copyButton.innerText = copiedMsg;
    setTimeout(() => copyButton.innerText = originalText, 1500);
  });

  output?.addEventListener('click', () => {
    if (output.value) output.select();
  });
</script>
