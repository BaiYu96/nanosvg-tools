---
interface Props {
  format: 'png' | 'jpg' | 'webp' | 'pdf' | 'icon';
}

const { format } = Astro.props;
const currentLang = Astro.currentLocale || 'en';
const formatLabel = format === 'icon' ? 'ICO' : format.toUpperCase();
const isLossy = format === 'jpg' || format === 'webp';
const needsOpaqueBg = format === 'jpg' || format === 'pdf';

const t = {
  en: {
    title: `SVG to ${formatLabel}`,
    subtitle: `Render SVG locally in your browser and download a ${formatLabel} file.`,
    paste: '1. Paste SVG Code',
    options: '2. Export Options',
    width: 'Width',
    height: 'Height',
    background: 'Background',
    transparent: 'Transparent',
    quality: 'Quality',
    preview: 'Preview',
    download: `Download ${formatLabel}`,
    downloadZip: 'Download ZIP',
    chooseFiles: 'Choose SVG files',
    dropHint: 'Drop SVG files here, or paste code below.',
    clearFiles: 'Clear files',
    selected: 'Selected files',
    noFiles: 'No files selected.',
    processed: 'Processed',
    skipped: 'Skipped',
    placeholder: '<svg viewBox="0 0 512 512"> ... </svg>',
    invalid: 'Invalid SVG code structure.',
    empty: 'Paste an SVG first.',
    ready: 'Ready to export.',
    failed: 'Export failed. Please check your SVG code.'
  },
  zh: {
    title: `SVG 转 ${formatLabel}`,
    subtitle: `在浏览器本地渲染 SVG，并下载 ${formatLabel} 文件。`,
    paste: '1. 粘贴 SVG 代码',
    options: '2. 导出设置',
    width: '宽度',
    height: '高度',
    background: '背景色',
    transparent: '透明',
    quality: '质量',
    preview: '预览',
    download: `下载 ${formatLabel}`,
    downloadZip: '下载 ZIP',
    chooseFiles: '选择 SVG 文件',
    dropHint: '将 SVG 文件拖拽到这里，或在下方粘贴代码。',
    clearFiles: '清空文件',
    selected: '已选文件',
    noFiles: '未选择文件。',
    processed: '已处理',
    skipped: '已跳过',
    placeholder: '<svg viewBox="0 0 512 512"> ... </svg>',
    invalid: 'SVG 代码结构无效，请检查。',
    empty: '请先粘贴 SVG。',
    ready: '已准备好导出。',
    failed: '导出失败，请检查 SVG 代码。'
  },
  de: {
    title: `SVG zu ${formatLabel}`,
    subtitle: `Rendern Sie SVG lokal im Browser und laden Sie eine ${formatLabel}-Datei herunter.`,
    paste: '1. SVG-Code einfügen',
    options: '2. Exportoptionen',
    width: 'Breite',
    height: 'Höhe',
    background: 'Hintergrund',
    transparent: 'Transparent',
    quality: 'Qualität',
    preview: 'Vorschau',
    download: `${formatLabel} herunterladen`,
    downloadZip: 'ZIP herunterladen',
    chooseFiles: 'SVG-Dateien wählen',
    dropHint: 'SVG-Dateien hier ablegen oder Code unten einfügen.',
    clearFiles: 'Dateien löschen',
    selected: 'Ausgewählte Dateien',
    noFiles: 'Keine Dateien ausgewählt.',
    processed: 'Verarbeitet',
    skipped: 'Übersprungen',
    placeholder: '<svg viewBox="0 0 512 512"> ... </svg>',
    invalid: 'Ungültige SVG-Codestruktur.',
    empty: 'Fügen Sie zuerst ein SVG ein.',
    ready: 'Bereit zum Export.',
    failed: 'Export fehlgeschlagen. Bitte prüfen Sie den SVG-Code.'
  }
}[currentLang as 'en' | 'zh' | 'de'];
---

<section class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col gap-6" data-export-format={format}>
  <div>
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-indigo-600">{t.title}</p>
    <h1 class="mt-2 text-2xl font-black text-slate-950">{t.title}</h1>
    <p class="mt-1 text-xs text-slate-500">{t.subtitle}</p>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-[1fr_280px] gap-5">
    <div class="flex flex-col gap-5">
      <div>
        <label for="svgExportInput" class="block text-sm font-bold text-slate-900 mb-2">{t.paste}</label>
        <div id="exportDropZone" class="mb-3 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-4 transition-colors">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs font-semibold text-slate-500">{t.dropHint}</p>
            <div class="flex items-center gap-2">
              <label class="inline-flex cursor-pointer items-center justify-center rounded-lg bg-slate-900 px-3 py-2 text-xs font-bold text-white transition-colors hover:bg-indigo-700">
                {t.chooseFiles}
                <input id="exportFiles" type="file" accept=".svg,image/svg+xml" multiple class="sr-only" />
              </label>
              <button id="clearExportFiles" type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-bold text-slate-600 hover:bg-slate-50">
                {t.clearFiles}
              </button>
            </div>
          </div>
          <div class="mt-4 rounded-lg border border-slate-200 bg-white p-3">
            <div class="flex items-center justify-between gap-3">
              <span class="text-xs font-bold uppercase tracking-wide text-slate-500">{t.selected}</span>
              <span id="exportFileCount" class="rounded-full bg-slate-100 px-2 py-1 text-[11px] font-bold text-slate-500">0</span>
            </div>
            <div id="exportFileList" class="mt-3 flex flex-col gap-2 text-xs text-slate-500">
              <span>{t.noFiles}</span>
            </div>
          </div>
        </div>
        <textarea
          id="svgExportInput"
          rows="10"
          class="w-full p-4 border border-slate-300 rounded-xl font-mono text-xs focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-slate-50"
          placeholder={t.placeholder}
        ></textarea>
      </div>

      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <h2 class="text-sm font-bold text-slate-900">{t.options}</h2>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <label class="flex flex-col gap-1 text-xs font-semibold text-slate-600">
            {t.width}
            <input id="exportWidth" type="number" min="16" max="4096" value={format === 'icon' ? 256 : 1024} class="rounded-xl border border-slate-300 bg-white px-3 py-2 font-mono text-xs" />
          </label>
          <label class="flex flex-col gap-1 text-xs font-semibold text-slate-600">
            {t.height}
            <input id="exportHeight" type="number" min="16" max="4096" value={format === 'icon' ? 256 : 1024} class="rounded-xl border border-slate-300 bg-white px-3 py-2 font-mono text-xs" />
          </label>
          <label class:list={["flex flex-col gap-1 text-xs font-semibold text-slate-600", !isLossy && "hidden"]}>
            {t.quality}
            <input id="exportQuality" type="range" min="0.1" max="1" step="0.05" value="0.92" class="h-9" />
          </label>
          <label class="flex flex-col gap-1 text-xs font-semibold text-slate-600">
            {t.background}
            <input id="exportBackground" type="color" value={needsOpaqueBg ? '#ffffff' : '#ffffff'} class="h-9 w-full rounded-xl border border-slate-300 bg-white px-2" />
          </label>
        </div>
        <label class:list={["mt-3 inline-flex items-center gap-2 text-xs font-semibold text-slate-600", needsOpaqueBg && "hidden"]}>
          <input id="transparentBackground" type="checkbox" checked class="h-4 w-4 rounded border-slate-300 text-indigo-600" />
          {t.transparent}
        </label>
      </div>
    </div>

    <aside class="flex flex-col gap-3">
      <h2 class="text-sm font-bold text-slate-900">{t.preview}</h2>
      <div class="min-h-[280px] rounded-xl border border-slate-200 bg-slate-50 p-4 flex items-center justify-center">
        <canvas id="exportPreview" width="256" height="256" class="max-h-[240px] max-w-full rounded-lg border border-slate-200 bg-white"></canvas>
      </div>
      <button id="downloadExport" class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-3 text-xs font-bold text-white transition-colors hover:bg-indigo-700">
        {t.download}
      </button>
      <p id="exportStatus" class="min-h-4 text-xs font-semibold text-slate-500"></p>
    </aside>
  </div>
</section>

<input type="hidden" id="exportDownloadMsg" value={t.download} />
<input type="hidden" id="exportDownloadZipMsg" value={t.downloadZip} />
<input type="hidden" id="exportNoFilesMsg" value={t.noFiles} />
<input type="hidden" id="exportProcessedMsg" value={t.processed} />
<input type="hidden" id="exportSkippedMsg" value={t.skipped} />
<input type="hidden" id="exportInvalidMsg" value={t.invalid} />
<input type="hidden" id="exportEmptyMsg" value={t.empty} />
<input type="hidden" id="exportReadyMsg" value={t.ready} />
<input type="hidden" id="exportFailedMsg" value={t.failed} />

<script>
  import { zipSync } from 'fflate';

  const section = document.querySelector('[data-export-format]') as HTMLElement;
  const format = section?.dataset.exportFormat as 'png' | 'jpg' | 'webp' | 'pdf' | 'icon';
  const input = document.getElementById('svgExportInput') as HTMLTextAreaElement;
  const fileInput = document.getElementById('exportFiles') as HTMLInputElement;
  const clearFilesButton = document.getElementById('clearExportFiles') as HTMLButtonElement;
  const dropZone = document.getElementById('exportDropZone');
  const fileCount = document.getElementById('exportFileCount');
  const fileList = document.getElementById('exportFileList');
  const widthInput = document.getElementById('exportWidth') as HTMLInputElement;
  const heightInput = document.getElementById('exportHeight') as HTMLInputElement;
  const qualityInput = document.getElementById('exportQuality') as HTMLInputElement;
  const backgroundInput = document.getElementById('exportBackground') as HTMLInputElement;
  const transparentInput = document.getElementById('transparentBackground') as HTMLInputElement;
  const previewCanvas = document.getElementById('exportPreview') as HTMLCanvasElement;
  const downloadButton = document.getElementById('downloadExport') as HTMLButtonElement;
  const status = document.getElementById('exportStatus');
  const downloadMsg = (document.getElementById('exportDownloadMsg') as HTMLInputElement)?.value || 'Download';
  const downloadZipMsg = (document.getElementById('exportDownloadZipMsg') as HTMLInputElement)?.value || 'Download ZIP';
  const noFilesMsg = (document.getElementById('exportNoFilesMsg') as HTMLInputElement)?.value || 'No files selected.';
  const processedMsg = (document.getElementById('exportProcessedMsg') as HTMLInputElement)?.value || 'Processed';
  const skippedMsg = (document.getElementById('exportSkippedMsg') as HTMLInputElement)?.value || 'Skipped';
  const invalidMsg = (document.getElementById('exportInvalidMsg') as HTMLInputElement)?.value || 'Invalid SVG code structure.';
  const emptyMsg = (document.getElementById('exportEmptyMsg') as HTMLInputElement)?.value || 'Paste an SVG first.';
  const readyMsg = (document.getElementById('exportReadyMsg') as HTMLInputElement)?.value || 'Ready to export.';
  const failedMsg = (document.getElementById('exportFailedMsg') as HTMLInputElement)?.value || 'Export failed.';
  let selectedItems: Array<{ name: string; source: string; status: 'ready' | 'invalid' }> = [];
  let isProgrammaticInput = false;

  const extensionMap = {
    png: 'png',
    jpg: 'jpg',
    webp: 'webp',
    pdf: 'pdf',
    icon: 'ico'
  };

  const mimeMap = {
    png: 'image/png',
    jpg: 'image/jpeg',
    webp: 'image/webp'
  };

  const parseSvg = (svgCode: string) => {
    const doc = new DOMParser().parseFromString(svgCode, 'image/svg+xml');
    if (doc.querySelector('parsererror')) return null;
    const svg = doc.documentElement;
    if (!svg || svg.tagName.toLowerCase() !== 'svg') return null;
    return svg;
  };

  const sanitizeSvg = (svgCode: string) => {
    const svg = parseSvg(svgCode);
    if (!svg) return null;
    const clone = svg.cloneNode(true) as SVGElement;
    clone.querySelectorAll('script, foreignObject').forEach((node) => node.remove());
    clone.querySelectorAll('*').forEach((node) => {
      [...node.attributes].forEach((attr) => {
        const name = attr.name.toLowerCase();
        const value = attr.value.trim().toLowerCase();
        if (name.startsWith('on') || value.startsWith('javascript:')) node.removeAttribute(attr.name);
      });
    });
    if (!clone.getAttribute('xmlns')) clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
    return new XMLSerializer().serializeToString(clone);
  };

  const canvasToBlob = (canvas: HTMLCanvasElement, type: string, quality?: number) => new Promise<Blob>((resolve, reject) => {
    canvas.toBlob((blob) => blob ? resolve(blob) : reject(new Error('Canvas export failed')), type, quality);
  });

  const renderToCanvas = async (source: string, size = { width: Number(widthInput.value), height: Number(heightInput.value) }) => {
    if (!source) throw new Error(emptyMsg);
    const svg = sanitizeSvg(source);
    if (!svg) throw new Error(invalidMsg);

    const svgBlob = new Blob([svg], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(svgBlob);
    const img = new Image();
    img.decoding = 'async';
    const loaded = new Promise<void>((resolve, reject) => {
      img.onload = () => resolve();
      img.onerror = () => reject(new Error(invalidMsg));
    });
    img.src = url;
    await loaded;
    URL.revokeObjectURL(url);

    const canvas = document.createElement('canvas');
    canvas.width = Math.max(16, Math.min(4096, size.width || 1024));
    canvas.height = Math.max(16, Math.min(4096, size.height || 1024));
    const ctx = canvas.getContext('2d');
    if (!ctx) throw new Error(failedMsg);

    const useTransparent = transparentInput?.checked && format !== 'jpg' && format !== 'pdf';
    if (!useTransparent) {
      ctx.fillStyle = backgroundInput.value || '#ffffff';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
    }

    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
    return canvas;
  };

  const copyCanvas = (source: HTMLCanvasElement, target: HTMLCanvasElement) => {
    target.width = 256;
    target.height = 256;
    const ctx = target.getContext('2d');
    if (!ctx) return;
    ctx.clearRect(0, 0, target.width, target.height);
    ctx.drawImage(source, 0, 0, target.width, target.height);
  };

  const uint8 = async (blob: Blob) => new Uint8Array(await blob.arrayBuffer());

  const makePdf = async (canvas: HTMLCanvasElement) => {
    const imageBytes = await uint8(await canvasToBlob(canvas, 'image/jpeg', 0.95));
    const width = canvas.width;
    const height = canvas.height;
    const objects: string[] = [];
    const imageObj = 4;
    objects.push('<< /Type /Catalog /Pages 2 0 R >>');
    objects.push('<< /Type /Pages /Kids [3 0 R] /Count 1 >>');
    objects.push(`<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ${width} ${height}] /Resources << /XObject << /Im0 ${imageObj} 0 R >> >> /Contents 5 0 R >>`);
    objects.push(`<< /Type /XObject /Subtype /Image /Width ${width} /Height ${height} /ColorSpace /DeviceRGB /BitsPerComponent 8 /Filter /DCTDecode /Length ${imageBytes.length} >>\nstream\n`);
    const content = `q\n${width} 0 0 ${height} 0 0 cm\n/Im0 Do\nQ`;
    objects.push(`<< /Length ${content.length} >>\nstream\n${content}\nendstream`);

    const encoder = new TextEncoder();
    const chunks: Uint8Array[] = [encoder.encode('%PDF-1.4\n')];
    const offsets = [0];
    let length = chunks[0].length;
    objects.forEach((object, index) => {
      offsets.push(length);
      const head = encoder.encode(`${index + 1} 0 obj\n`);
      chunks.push(head);
      length += head.length;
      chunks.push(encoder.encode(object));
      length += encoder.encode(object).length;
      if (index === 3) {
        chunks.push(imageBytes);
        length += imageBytes.length;
        const tail = encoder.encode('\nendstream\nendobj\n');
        chunks.push(tail);
        length += tail.length;
      } else {
        const tail = encoder.encode('\nendobj\n');
        chunks.push(tail);
        length += tail.length;
      }
    });
    const xrefOffset = length;
    const xref = `xref\n0 ${objects.length + 1}\n0000000000 65535 f \n${offsets.slice(1).map((offset) => `${String(offset).padStart(10, '0')} 00000 n `).join('\n')}\ntrailer\n<< /Size ${objects.length + 1} /Root 1 0 R >>\nstartxref\n${xrefOffset}\n%%EOF`;
    chunks.push(encoder.encode(xref));
    return new Blob(chunks, { type: 'application/pdf' });
  };

  const makeIco = async (source: string) => {
    const sizes = [16, 32, 48, 64, 128, 256];
    const pngs = await Promise.all(sizes.map(async (size) => {
      const canvas = await renderToCanvas(source, { width: size, height: size });
      return { size, bytes: await uint8(await canvasToBlob(canvas, 'image/png')) };
    }));

    const headerSize = 6 + pngs.length * 16;
    const totalSize = headerSize + pngs.reduce((sum, item) => sum + item.bytes.length, 0);
    const buffer = new ArrayBuffer(totalSize);
    const view = new DataView(buffer);
    const bytes = new Uint8Array(buffer);
    view.setUint16(0, 0, true);
    view.setUint16(2, 1, true);
    view.setUint16(4, pngs.length, true);
    let offset = headerSize;
    pngs.forEach((item, index) => {
      const entry = 6 + index * 16;
      view.setUint8(entry, item.size === 256 ? 0 : item.size);
      view.setUint8(entry + 1, item.size === 256 ? 0 : item.size);
      view.setUint8(entry + 2, 0);
      view.setUint8(entry + 3, 0);
      view.setUint16(entry + 4, 1, true);
      view.setUint16(entry + 6, 32, true);
      view.setUint32(entry + 8, item.bytes.length, true);
      view.setUint32(entry + 12, offset, true);
      bytes.set(item.bytes, offset);
      offset += item.bytes.length;
    });
    return new Blob([buffer], { type: 'image/x-icon' });
  };

  const updateFileList = () => {
    if (fileCount) fileCount.textContent = String(selectedItems.length);
    if (downloadButton) downloadButton.textContent = selectedItems.length > 1 ? downloadZipMsg : downloadMsg;
    fileList?.replaceChildren();

    if (!selectedItems.length) {
      const empty = document.createElement('span');
      empty.textContent = noFilesMsg;
      fileList?.appendChild(empty);
      return;
    }

    selectedItems.forEach((item) => {
      const row = document.createElement('div');
      row.className = 'flex items-center justify-between gap-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2';
      const name = document.createElement('span');
      name.className = 'truncate font-mono text-[11px] text-slate-600';
      name.textContent = item.name;
      const badge = document.createElement('span');
      badge.className = item.status === 'ready'
        ? 'shrink-0 rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-bold text-emerald-700'
        : 'shrink-0 rounded-full bg-red-50 px-2 py-0.5 text-[10px] font-bold text-red-700';
      badge.textContent = item.status;
      row.append(name, badge);
      fileList?.appendChild(row);
    });
  };

  const setInputSource = (source: string) => {
    isProgrammaticInput = true;
    input.value = source;
    isProgrammaticInput = false;
  };

  const addFiles = async (files: File[]) => {
    const svgFiles = files.filter((file) => file.type === 'image/svg+xml' || file.name.toLowerCase().endsWith('.svg'));
    const nextItems = await Promise.all(svgFiles.map(async (file) => {
      const source = await file.text();
      return {
        name: file.name,
        source,
        status: parseSvg(source) ? 'ready' as const : 'invalid' as const
      };
    }));

    selectedItems = [...selectedItems, ...nextItems];
    fileInput.value = '';
    updateFileList();

    const firstReady = selectedItems.find((item) => item.status === 'ready');
    if (firstReady) {
      setInputSource(firstReady.source);
      await refreshPreview();
    } else {
      await refreshPreview();
    }
  };

  const clearSelectedFiles = async () => {
    selectedItems = [];
    fileInput.value = '';
    updateFileList();
    await refreshPreview();
  };

  const refreshPreview = async () => {
    status!.textContent = '';
    try {
      const previewSource = selectedItems.find((item) => item.status === 'ready')?.source || input.value.trim();
      if (!previewSource) {
        const ctx = previewCanvas.getContext('2d');
        ctx?.clearRect(0, 0, previewCanvas.width, previewCanvas.height);
        status!.textContent = emptyMsg;
        return;
      }
      const canvas = await renderToCanvas(previewSource);
      copyCanvas(canvas, previewCanvas);
      status!.textContent = readyMsg;
      status?.classList.remove('text-red-600');
      status?.classList.add('text-emerald-600');
    } catch (error) {
      status!.textContent = error instanceof Error ? error.message : failedMsg;
      status?.classList.remove('text-emerald-600');
      status?.classList.add('text-red-600');
    }
  };

  const downloadBlob = (blob: Blob, filename = `nanosvg-export.${extensionMap[format]}`) => {
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = filename;
    link.click();
    URL.revokeObjectURL(url);
  };

  const baseName = (name: string) => name.replace(/\.svg$/i, '').replace(/[^\w.-]+/g, '-').replace(/^-+|-+$/g, '') || 'nanosvg-export';

  const uniqueFileName = (name: string, usedNames: Set<string>) => {
    const extension = extensionMap[format];
    const base = baseName(name);
    let candidate = `${base}.${extension}`;
    let index = 2;
    while (usedNames.has(candidate)) {
      candidate = `${base}-${index}.${extension}`;
      index += 1;
    }
    usedNames.add(candidate);
    return candidate;
  };

  const exportSource = async (source: string) => {
    if (format === 'icon') return makeIco(source);
    const canvas = await renderToCanvas(source);
    if (format === 'pdf') return makePdf(canvas);
    const mime = mimeMap[format as keyof typeof mimeMap];
    const quality = Number(qualityInput?.value || 0.92);
    return canvasToBlob(canvas, mime, quality);
  };

  const exportZip = async () => {
    const zipFiles: Record<string, Uint8Array> = {};
    const usedNames = new Set<string>();
    let processed = 0;
    let skipped = 0;
    const readyItems = selectedItems.filter((item) => item.status === 'ready');

    for (const item of readyItems) {
      try {
        status!.textContent = `${processedMsg}: ${processed}/${readyItems.length} · ${skippedMsg}: ${skipped}`;
        const blob = await exportSource(item.source);
        zipFiles[uniqueFileName(item.name, usedNames)] = await uint8(blob);
        processed += 1;
      } catch (error) {
        skipped += 1;
      }
    }

    skipped += selectedItems.length - readyItems.length;
    if (!processed) throw new Error(invalidMsg);

    const zipped = zipSync(zipFiles);
    downloadBlob(new Blob([zipped], { type: 'application/zip' }), `nanosvg-${format}-exports.zip`);
    status!.textContent = `${processedMsg}: ${processed} · ${skippedMsg}: ${skipped}`;
    status?.classList.remove('text-red-600');
    status?.classList.add('text-emerald-600');
  };

  const exportFile = async () => {
    try {
      if (selectedItems.length > 1) {
        await exportZip();
        return;
      }

      const item = selectedItems[0];
      const source = item?.source || input.value.trim();
      const blob = await exportSource(source);
      if (format !== 'icon' && format !== 'pdf') {
        const canvas = await renderToCanvas(source);
        copyCanvas(canvas, previewCanvas);
      }
      downloadBlob(blob, item ? uniqueFileName(item.name, new Set()) : undefined);
    } catch (error) {
      status!.textContent = error instanceof Error ? error.message : failedMsg;
      status?.classList.remove('text-emerald-600');
      status?.classList.add('text-red-600');
    }
  };

  input?.addEventListener('input', () => {
    if (!isProgrammaticInput && selectedItems.length) {
      selectedItems = [];
      updateFileList();
    }
    refreshPreview();
  });
  fileInput?.addEventListener('change', () => addFiles([...(fileInput.files || [])]));
  clearFilesButton?.addEventListener('click', clearSelectedFiles);
  dropZone?.addEventListener('dragover', (event) => {
    event.preventDefault();
    dropZone.classList.add('border-indigo-300', 'bg-indigo-50');
  });
  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-indigo-300', 'bg-indigo-50');
  });
  dropZone?.addEventListener('drop', (event) => {
    event.preventDefault();
    dropZone.classList.remove('border-indigo-300', 'bg-indigo-50');
    addFiles([...(event.dataTransfer?.files || [])]);
  });
  widthInput?.addEventListener('input', refreshPreview);
  heightInput?.addEventListener('input', refreshPreview);
  qualityInput?.addEventListener('input', refreshPreview);
  backgroundInput?.addEventListener('input', refreshPreview);
  transparentInput?.addEventListener('change', refreshPreview);
  downloadButton?.addEventListener('click', exportFile);
  updateFileList();
</script>
