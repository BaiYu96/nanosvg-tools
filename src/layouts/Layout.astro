---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
// 💡 关键：获取当前页面所属的语言（'en' 或 'zh' 或 'de'）
const currentLang = Astro.currentLocale || 'en';
const pathname = Astro.url.pathname;
const homeUrl = currentLang === 'en' ? '/' : `/${currentLang}/`;
const converterUrl = currentLang === 'en' ? '/svg2base64/' : `/${currentLang}/svg2base64/`;
const optimizerUrl = currentLang === 'en' ? '/optimizer/' : `/${currentLang}/optimizer/`;
const componentUrl = currentLang === 'en' ? '/component/' : `/${currentLang}/component/`;
const spriteUrl = currentLang === 'en' ? '/sprite/' : `/${currentLang}/sprite/`;
const exportSlugs = ['svg2png', 'svg2jpg', 'svg2webp', 'svg2pdf', 'svg2icon'];
const activeExportSlug = exportSlugs.find((slug) => pathname.includes(`/${slug}`));
const isHome = pathname === '/' || pathname === '/zh/' || pathname === '/de/';
const isConverter = pathname.includes('/svg2base64');
const isOptimizer = pathname.includes('/optimizer');
const isComponent = pathname.includes('/component');
const isSprite = pathname.includes('/sprite');
const navText = {
	en: {
		home: 'Tools',
		converter: 'Converter',
		optimizer: 'Optimizer',
		component: 'Component',
		sprite: 'Sprite',
		features: 'Features',
		faq: 'FAQ',
		privacyTitle: 'Privacy Guarantee',
		privacyBody: 'NanoSVG Tools is built with a serverless architecture. Your vector files and source codes never leave your local machine, ensuring complete data sovereignty.',
		openSource: 'Open Source',
		star: 'Star on GitHub'
	},
	zh: {
		home: '工具箱',
		converter: '转换工具',
		optimizer: '压缩优化',
		component: '转组件',
		sprite: '精灵图',
		features: '功能',
		faq: 'FAQ',
		privacyTitle: '隐私保障',
		privacyBody: 'NanoSVG Tools 采用无服务器架构。您的矢量文件和源码不会离开本地设备，确保资产始终由您掌控。',
		openSource: '开源项目',
		star: '在 GitHub 查看'
	},
	de: {
		home: 'Tools',
		converter: 'Konverter',
		optimizer: 'Optimizer',
		component: 'Komponente',
		sprite: 'Sprite',
		features: 'Features',
		faq: 'FAQ',
		privacyTitle: 'Datenschutzgarantie',
		privacyBody: 'NanoSVG Tools arbeitet ohne Server-Upload. Ihre Vektordateien und Quellcodes verlassen Ihr lokales Gerät nicht.',
		openSource: 'Open Source',
		star: 'Auf GitHub ansehen'
	}
}[currentLang as 'en' | 'zh' | 'de'];
---
<style is:global>
@import "tailwindcss";
</style>

<!doctype html>
<html lang={currentLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
	</head>
	<body class="bg-slate-50 text-slate-800 font-sans min-h-screen flex flex-col">
		<header class="bg-white border-b border-slate-200 py-4 px-6 shadow-sm">
			<div class="max-w-6xl mx-auto flex justify-between items-center">
				<a href={homeUrl} class="text-xl font-bold text-indigo-600 flex items-center gap-2">
					⚡ NanoSVG Tools
				</a>
<nav class="flex items-center gap-3 text-sm text-slate-600">
					<a href={homeUrl} class:list={["hover:text-indigo-600 font-medium", isHome && "text-indigo-600"]}>{navText.home}</a>
					<a href={converterUrl} class:list={["hover:text-indigo-600 font-medium", isConverter && "text-indigo-600"]}>{navText.converter}</a>
					<a href={optimizerUrl} class:list={["hover:text-indigo-600 font-medium", isOptimizer && "text-indigo-600"]}>{navText.optimizer}</a>
					<a href={componentUrl} class:list={["hover:text-indigo-600 font-medium hidden md:inline", isComponent && "text-indigo-600"]}>{navText.component}</a>
					<a href={spriteUrl} class:list={["hover:text-indigo-600 font-medium hidden md:inline", isSprite && "text-indigo-600"]}>{navText.sprite}</a>
					<a href="#features" class="hover:text-indigo-600 hidden sm:inline">{navText.features}</a>
					<a href="#faq" class="hover:text-indigo-600 hidden sm:inline">{navText.faq}</a>
					
					<div class="relative inline-block text-left border-l border-slate-200 pl-4">
						<select 
							onchange="location = this.value;" 
							class="bg-slate-50 border border-slate-300 text-slate-700 py-1 px-2 rounded-md text-xs font-medium focus:outline-none focus:ring-1 focus:ring-indigo-500 cursor-pointer"
						>
							<option value={activeExportSlug ? `/${activeExportSlug}/` : isConverter ? '/svg2base64/' : isOptimizer ? '/optimizer/' : isComponent ? '/component/' : isSprite ? '/sprite/' : '/'} selected={currentLang === 'en'}>🇺🇸 English</option>
							<option value={activeExportSlug ? `/zh/${activeExportSlug}/` : isConverter ? '/zh/svg2base64/' : isOptimizer ? '/zh/optimizer/' : isComponent ? '/zh/component/' : isSprite ? '/zh/sprite/' : '/zh/'} selected={currentLang === 'zh'}>🇨🇳 简体中文</option>
							<option value={activeExportSlug ? `/de/${activeExportSlug}/` : isConverter ? '/de/svg2base64/' : isOptimizer ? '/de/optimizer/' : isComponent ? '/de/component/' : isSprite ? '/de/sprite/' : '/de/'} selected={currentLang === 'de'}>🇩🇪 Deutsch</option>
						</select>
					</div>
					<a
						href="https://github.com/BaiYu96/nanosvg-tools"
						target="_blank"
						rel="noreferrer"
						aria-label="GitHub"
						class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-slate-50 text-slate-700 transition-colors hover:border-slate-400 hover:bg-white hover:text-indigo-600"
					>
						<svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4 fill-current">
							<path d="M12 2C6.48 2 2 6.58 2 12.24c0 4.52 2.87 8.35 6.84 9.7.5.09.68-.22.68-.49v-1.72c-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.35 1.11 2.92.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.32 9.32 0 0 1 12 6.98c.85 0 1.7.12 2.5.35 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.04.36.32.68.94.68 1.9v2.77c0 .27.18.59.69.49A10.05 10.05 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z" />
						</svg>
					</a>
				</nav>
			</div>
		</header>

		<!-- 核心内容区 + 响应式双翼/侧边广告栏布局 -->
		<main class="flex-1 max-w-7xl w-full mx-auto px-4 py-8 grid grid-cols-1 lg:grid-cols-4 gap-8">
			
			<!-- 左侧/中间：工具核心与SEO文章 (占 3 个网格) -->
			<div class="lg:col-span-3 flex flex-col gap-8">
				<slot />
			</div>

		
      <aside class="hidden lg:block lg:col-span-1">
	<div class="sticky top-8 w-[300px] bg-white border border-slate-200 rounded-2xl p-6 flex flex-col gap-4 shadow-sm">
		<div class="flex items-center gap-2 text-indigo-600 font-bold text-sm">
			<span>🔒 {navText.privacyTitle}</span>
		</div>
		<p class="text-xs text-slate-500 leading-relaxed">
			{navText.privacyBody}
		</p>
		<div class="border-t border-slate-100 pt-3 flex flex-col gap-2">
			<span class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider">{navText.openSource}</span>
			<a href="https://github.com/BaiYu96/nanosvg-tools" target="_blank" class="text-xs text-slate-600 hover:text-indigo-600 flex items-center gap-1">
				⭐ {navText.star} →
			</a>
		</div>
	</div>
</aside>
		</main>

		<footer class="bg-slate-900 text-slate-400 text-xs py-6 border-t border-slate-800 mt-12 text-center">
			<p>© 2026 NanoSVG Tools. 100% Client-Side & Privacy-First.</p>
		</footer>
	</body>
</html>
